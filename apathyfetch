#!/bin/zsh

# 1. Определение пути к скрипту
if [[ -n "$ZSH_VERSION" ]]; then
    SCRIPT_SOURCE="${ZSH_ARGZERO:-${(%):-%N}}"
    SELF_PATH=$(dirname "$SCRIPT_SOURCE")
    if [[ "$SELF_PATH" != /* ]]; then
        SELF_PATH="$(cd "$SELF_PATH" && pwd)"
    fi
else
    SELF_PATH=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
fi

IMG_DIR="$SELF_PATH/images"
MODE="normal"
ANIMATE=false
USE_CHAFA=false
TARGET_IMG=""

# Обработка аргументов
for arg in "$@"; do
    case $arg in
        --hello) MODE="hello" ;;
        --gif) ANIMATE=true ;;
        --chafa) USE_CHAFA=true ;;
    esac
done

# --- ЛОГИКА ВЫБОРА ФАЙЛА ---

if [[ "$ANIMATE" == true ]]; then
    # Режим анимации: ищем ТОЛЬКО .gif
    if [[ -f "$IMG_DIR/wall.gif" ]]; then
        TARGET_IMG="$IMG_DIR/wall.gif"
    else
        echo -e "\e[1;31mError:\e[0m Flag --gif used, but 'images/wall.gif' not found."
        exit 1
    fi
else
    # Режим статики: ищем ТОЛЬКО картинки (не gif)
    FOUND_STATIC=false
    for ext in jpg jpeg png heic webp bmp tiff JPG JPEG PNG HEIC WEBP BMP TIFF; do
        if [[ -f "$IMG_DIR/wall.$ext" ]]; then
            TARGET_IMG="$IMG_DIR/wall.$ext"
            FOUND_STATIC=true
            break
        fi
    done

    if [[ "$FOUND_STATIC" == false ]]; then
        # Если статики нет, но есть гифка и не просили явно статику - можно попробовать её, но по ТЗ игнорируем
        echo -e "\e[1;31mError:\e[0m No static image found (wall.jpg, wall.png, etc.)."
        exit 1
    fi
fi

# --- ПРОВЕРКА CHAFA ---
if [[ "$USE_CHAFA" == true ]]; then
    if ! command -v chafa &> /dev/null; then
        echo -e "\e[1;31mError:\e[0m Flag --chafa used, but 'chafa' is not installed."
        echo "Install it via Homebrew: brew install chafa"
        exit 1
    fi
fi

# Очистка экрана
printf "\033[H\033[2J\033[3J"

# --- НАСТРОЙКИ ---
# Для Chafa ширина задается в символах, для Kitty - тоже примерно в символах
IMG_WIDTH=40
GAP=4
TEXT_COL=$((IMG_WIDTH + GAP))
BOTTOM_GAP=5 # Чуть больше отступ для Chafa, так как символы выше

# --- ОТРИСОВКА ИЗОБРАЖЕНИЯ ---

if [[ "$USE_CHAFA" == true ]]; then
    # РЕЖИМ CHAFA
    # Выводим изображение прямо в поток. Chafa сам обработает GIF (анимация) или картинку.
    # --size ограничивает ширину/высоту в символах.
    # --format symbols дает наилучшее качество.
    
    # Печатаем Chafa вывод. 
    # Важно: Chafa выводит сразу много строк. Нам нужно убедиться, что курсор потом встанет правильно.
    chafa "$TARGET_IMG" --size ${IMG_WIDTH}x --format symbols --align left
    
    # После вывода Chafa курсор находится под картинкой.
    # Нам нужно поднять его вверх на высоту картинки и сдвинуть вправо?
    # Нет, Chafa выводит картинку сверху вниз. Текст должен быть справа.
    # Но Chafa выводит поток строк. Мы не можем легко "вклиниться" справа в поток.
    # Решение для Chafa: 
    # 1. Сохранить вывод chafa во временную переменную? (Тяжело для GIF).
    # 2. Хак: Вывести картинку, потом вернуть курсор в начало (1,1), сдвинуть вправо и печатать текст поверх?
    #    Проблема: если текст длиннее картинки, он затрет нижнюю часть.
    #    Решение: Печатать текст ПОСЛЕ картинки, но со сдвигом? Нет, тогда будет столбиком.
    
    # Правильный подход для Chafa в одном потоке:
    # Мы не можем делать параллельные колонки легко в shell без ncurses, если выводим поток.
    # НО! Мы можем использовать трюк:
    # 1. Узнать высоту вывода Chafa (сложно заранее).
    # 2. Или просто вывести картинку, затем перевести курсор ВВЕРХ на нужное количество строк и вправо.
    
    # Попробуем такой вариант:
    # Выводим картинку. Считаем, что она займет ~IMG_ROWS строк (зависит от аспекта).
    # Для простоты в режиме Chafa мы сделаем вывод: Картинка, потом под ней Текст?
    # Нет, пользователь хочет "как раньше", т.е. справа.
    
    # Реализация "Справа" для Chafa сложна в чистом bash/zsh без буферизации всего экрана.
    # Компромисс: В режиме --chafa мы выводим картинку, затем переводим курсор в начало (1,1), 
    # сдвигаем вправо на IMG_WIDTH+GAP и печатаем текст.
    # Но если текст длиннее картинки, он пойдет ниже картинки по правой колонке. Это ок.
    # Главное - поднять курсор обратно вверх перед печатью текста.
    
    # Сколько строк заняла картинка? Chafa не говорит. 
    # Приблизительно: высота картинки / высота символа. 
    # Допустим, картинка 40 символов шириной. При 16:9 высота будет ~22 строки.
    # Давайте возьмем с запасом 30 строк.
    
    ESTIMATED_IMG_ROWS=30
    
    # Возвращаем курсор в верхний левый угол
    printf "\e[1;1H"
    # Сдвигаем вправо
    printf "\e[${TEXT_COL}G"
    
else
    # РЕЖИМ KITTY (Стандартный)
    kitten icat --clear
    kitten icat --place "${IMG_WIDTH}x18@0x0" --align left "$TARGET_IMG"
    
    # Возвращаем курсор в верхний левый угол для печати текста справа
    printf "\e[1;1H"
    printf "\e[${TEXT_COL}G"
fi

# Цвета
c="\e[1;35m"
r="\e[0m"

# Функция печати строки со сдвигом
print_line() {
    printf "\e[${TEXT_COL}G%b\n" "$1"
}

# --- ФУНКЦИЯ БАТАРЕИ ---
get_battery_info() {
    local raw_output b_percent b_state b_time_str b_minutes h m
    raw_output=$(pmset -g batt 2>/dev/null)
    
    if [[ -z "$raw_output" ]]; then
        echo "N/A|No Battery|Unknown"
        return
    fi

    b_percent=$(echo "$raw_output" | grep -oE "[0-9]+%" | head -1 | tr -d '%')
    
    if echo "$raw_output" | grep -q "charging"; then
        b_state="Charging"
    elif echo "$raw_output" | grep -q "discharging"; then
        b_state="Discharging"
    elif echo "$raw_output" | grep -q "AC attached"; then
        b_state="AC Attached"
    else
        b_state="Unknown"
    fi

    b_time_str=$(echo "$raw_output" | grep -oE "[0-9]+:[0-9]+ remaining" | head -1)
    
    if [[ -n "$b_time_str" ]]; then
        local hours_part=${b_time_str%%:*}
        local mins_part=${b_time_str##*:}
        mins_part=${mins_part%% *}
        b_minutes=$((10#$hours_part * 60 + 10#$mins_part))
    else
        b_minutes=$(echo "$raw_output" | grep -oE "\([0-9]+ minutes" | grep -oE "[0-9]+" | head -1)
        if [[ -z "$b_minutes" ]] && [[ -n "$b_percent" ]]; then
            b_minutes=$((b_percent * 2)) 
        fi
    fi

    if [[ -n "$b_minutes" ]] && [[ "$b_minutes" =~ ^[0-9]+$ ]]; then
        h=$((b_minutes / 60))
        m=$((b_minutes % 60))
        if [[ "$h" -gt 0 ]]; then
            b_time="${h}h ${m}m"
        else
            b_time="< 1h (${m}m)"
        fi
    else
        b_time="Calculating..."
    fi

    echo "${b_percent:-0}|${b_state}|${b_time}"
}

# --- ОСНОВНАЯ ЛОГИКА ---
if [[ "$MODE" == "hello" ]]; then
    USER_NAME="$USER"
    CURRENT_DATE=$(date "+%B %d, %Y")
    CURRENT_TIME=$(date "+%H:%M")
    DAY_OF_WEEK=$(date "+%A")

    IFS='|' read -r BAT_P BAT_S BAT_T <<< "$(get_battery_info)"

    print_line "${c}Hello, ${USER_NAME}${r}"
    print_line "-------------------"
    print_line "Today is ${c}${DAY_OF_WEEK}${r}, ${c}${CURRENT_DATE}${r}"
    print_line "Current time: ${c}${CURRENT_TIME}${r}"
    
    if [[ "$BAT_P" == "N/A" ]]; then
        print_line "Battery: ${c}No Battery${r}"
        print_line "Est. time left: ${c}N/A${r}"
    else
        print_line "Battery: ${c}${BAT_P}%${r} (${BAT_S})"
        print_line "Est. time left: ${c}${BAT_T}${r}"
    fi
    
    print_line ""
    print_line "${c}I am at your service.${r}"

else
    print_line "${c}${USER}${r}@${c}$(hostname -s)${r}"
    print_line "-------------------"
    print_line "${c}OS:${r}         macOS $(sw_vers -productVersion)"
    print_line "${c}Host:${r}       $(sysctl -n hw.model)"
    print_line "${c}Kernel:${r}     $(uname -r)"
    print_line "${c}Shell:${r}      zsh $ZSH_VERSION"
    
    CPU=$(sysctl -n machdep.cpu.brand_string | sed 's/(R)//g; s/(TM)//g')
    print_line "${c}CPU:${r}        ${CPU}"
    
    GPU=$(system_profiler SPDisplaysDataType 2>/dev/null | grep -m1 "Chipset Model" | sed 's/.*: //')
    print_line "${c}GPU:${r}        ${GPU:-Unknown}"
    
    MEM_TOTAL=$(($(sysctl -n hw.memsize) / 1024 / 1024 / 1024))
    print_line "${c}Memory:${r}     ${MEM_TOTAL} GB"

    IFS='|' read -r BAT_P _ _ <<< "$(get_battery_info)"
    if [[ "$BAT_P" != "N/A" ]]; then
        print_line "${c}Battery:${r}    ${BAT_P}%"
    fi

    print_line ""
    # Цветные квадратики
    printf "\e[${TEXT_COL}G"
    for i in {0..7}; do printf "\e[4${i}m  "; done; printf "${r}\n"
fi

# --- ФИНАЛЬНЫЙ ОТСТУП СНIZУ ---
# Для Chafa высота может быть больше, берем с запасом
if [[ "$USE_CHAFA" == true ]]; then
    FINAL_ROW=$((ESTIMATED_IMG_ROWS + BOTTOM_GAP))
else
    FINAL_ROW=$((18 + BOTTOM_GAP)) # 18 - высота для Kitty
fi

printf "\e[${FINAL_ROW};1H"
printf "${r}\e[0m"