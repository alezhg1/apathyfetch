#!/bin/zsh

if [[ -n "$ZSH_VERSION" ]]; then
    SCRIPT_SOURCE="${ZSH_ARGZERO:-${(%):-%N}}"
    SELF_PATH=$(dirname "$SCRIPT_SOURCE")
    if [[ "$SELF_PATH" != /* ]]; then
        SELF_PATH="$(cd "$SELF_PATH" && pwd)"
    fi
else
    SELF_PATH=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
fi

IMG="$SELF_PATH/images/wall.jpeg"
MODE="normal"

if [[ "$1" == "--hello" ]]; then
    MODE="hello"
fi

if [[ ! -f "$IMG" ]]; then
    echo "Error: Image not found at $IMG"
    exit 1
fi

printf "\033[H\033[2J\033[3J"

IMG_COLS=45
IMG_ROWS=18
GAP=4
TEXT_COL=$((IMG_COLS + GAP))
BOTTOM_GAP=3

kitten icat --clear
kitten icat --place "${IMG_COLS}x${IMG_ROWS}@0x0" --align left "$IMG"

c="\e[1;35m"
r="\e[0m"

printf "\e[1;1H"
printf "\e[${TEXT_COL}G"

print_line() {
    printf "\e[${TEXT_COL}G%b\n" "$1"
}

get_battery_info() {
    local raw_output b_percent b_state b_time_str b_minutes h m
    raw_output=$(pmset -g batt 2>/dev/null)
    
    if [[ -z "$raw_output" ]]; then
        echo "N/A|No Battery|Unknown"
        return
    fi

    b_percent=$(echo "$raw_output" | grep -oE "[0-9]+%" | head -1 | tr -d '%')
    
    if echo "$raw_output" | grep -q "charging"; then
        b_state="Charging"
    elif echo "$raw_output" | grep -q "discharging"; then
        b_state="Discharging"
    elif echo "$raw_output" | grep -q "AC attached"; then
        b_state="AC Attached"
    else
        b_state="Unknown"
    fi

    b_time_str=$(echo "$raw_output" | grep -oE "[0-9]+:[0-9]+ remaining" | head -1)
    
    if [[ -n "$b_time_str" ]]; then
        local hours_part=${b_time_str%%:*}
        local mins_part=${b_time_str##*:}
        mins_part=${mins_part%% *}
        b_minutes=$((10#$hours_part * 60 + 10#$mins_part))
    else
        b_minutes=$(echo "$raw_output" | grep -oE "\([0-9]+ minutes" | grep -oE "[0-9]+" | head -1)
        if [[ -z "$b_minutes" ]] && [[ -n "$b_percent" ]]; then
            b_minutes=$((b_percent * 2)) 
        fi
    fi

    if [[ -n "$b_minutes" ]] && [[ "$b_minutes" =~ ^[0-9]+$ ]]; then
        h=$((b_minutes / 60))
        m=$((b_minutes % 60))
        if [[ "$h" -gt 0 ]]; then
            b_time="${h}h ${m}m"
        else
            b_time="< 1h (${m}m)"
        fi
    else
        b_time="Calculating..."
    fi

    echo "${b_percent:-0}|${b_state}|${b_time}"
}

# Исправленная функция анимации
type_text() {
    local text="$1"
    local delay="${2:-0.02}"
    local i=0
    local len=${#text}
    local char
    
    while (( i < len )); do
        char="${text:i:1}"
        
        # Если нашли начало escape-последовательности (\e или \033)
        if [[ "$char" == $'\e' ]] || [[ "$char" == $'\033' ]]; then
            # Ищем конец последовательности (буква в конце, например 'm')
            local j=$((i + 1))
            while (( j < len )); do
                local sub="${text:j:1}"
                printf "%b" "$sub" # Выводим часть кода цвета мгновенно
                ((j++))
                # Если встретили управляющую букву (m, H, G, A, B и т.д.), стоп
                if [[ "$sub" =~ [a-zA-Z] ]]; then
                    break
                fi
            done
            i=$j
        else
            # Обычный символ: печатаем с задержкой
            printf "%b" "$char"
            sleep "$delay"
            ((i++))
        fi
    done
    printf "\n"
}

print_line_animated() {
    local text="$1"
    local delay="${2:-0.02}"
    printf "\e[${TEXT_COL}G"
    type_text "$text" "$delay"
}

if [[ "$MODE" == "hello" ]]; then
    USER_NAME="$USER"
    CURRENT_DATE=$(date "+%B %d, %Y")
    CURRENT_TIME=$(date "+%H:%M")
    DAY_OF_WEEK=$(date "+%A")

    IFS='|' read -r BAT_P BAT_S BAT_T <<< "$(get_battery_info)"

    print_line_animated "${c}Hello, ${USER_NAME}${r}" 0.03
    sleep 0.1
    print_line_animated "-------------------" 0.01
    sleep 0.1
    print_line_animated "Today is ${c}${DAY_OF_WEEK}${r}, ${c}${CURRENT_DATE}${r}" 0.02
    print_line_animated "Current time: ${c}${CURRENT_TIME}${r}" 0.02
    
    if [[ "$BAT_P" == "N/A" ]]; then
        print_line_animated "Battery: ${c}No Battery${r}" 0.02
        print_line_animated "Est. time left: ${c}N/A${r}" 0.02
    else
        print_line_animated "Battery: ${c}${BAT_P}%${r} (${BAT_S})" 0.02
        print_line_animated "Est. time left: ${c}${BAT_T}${r}" 0.02
    fi
    
    print_line ""
    sleep 0.2
    print_line_animated "${c}I am at your service.${r}" 0.04

else
    print_line "${c}${USER}${r}@${c}$(hostname -s)${r}"
    print_line "-------------------"
    print_line "${c}OS:${r}         macOS $(sw_vers -productVersion)"
    print_line "${c}Host:${r}       $(sysctl -n hw.model)"
    print_line "${c}Kernel:${r}     $(uname -r)"
    print_line "${c}Shell:${r}      zsh $ZSH_VERSION"
    
    CPU=$(sysctl -n machdep.cpu.brand_string | sed 's/(R)//g; s/(TM)//g')
    print_line "${c}CPU:${r}        ${CPU}"
    
    GPU=$(system_profiler SPDisplaysDataType 2>/dev/null | grep -m1 "Chipset Model" | sed 's/.*: //')
    print_line "${c}GPU:${r}        ${GPU:-Unknown}"
    
    MEM_TOTAL=$(($(sysctl -n hw.memsize) / 1024 / 1024 / 1024))
    print_line "${c}Memory:${r}     ${MEM_TOTAL} GB"

    IFS='|' read -r BAT_P _ _ <<< "$(get_battery_info)"
    if [[ "$BAT_P" != "N/A" ]]; then
        print_line "${c}Battery:${r}    ${BAT_P}%"
    fi

    print_line ""
    printf "\e[${TEXT_COL}G"
    for i in {0..7}; do printf "\e[4${i}m  "; done; printf "${r}\n"
fi

FINAL_ROW=$((IMG_ROWS + BOTTOM_GAP))
printf "\e[${FINAL_ROW};1H"
printf "${r}\e[0m"