#!/bin/zsh

# 1. Определение пути к скрипту
if [[ -n "$ZSH_VERSION" ]]; then
    SCRIPT_SOURCE="${ZSH_ARGZERO:-${(%):-%N}}"
    SELF_PATH=$(dirname "$SCRIPT_SOURCE")
    if [[ "$SELF_PATH" != /* ]]; then
        SELF_PATH="$(cd "$SELF_PATH" && pwd)"
    fi
else
    SELF_PATH=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
fi

IMG="$SELF_PATH/images/wall.jpeg"
MODE="normal"

# Обработка аргументов
if [[ "$1" == "--hello" ]]; then
    MODE="hello"
fi

# Проверка картинки
if [[ ! -f "$IMG" ]]; then
    echo "Error: Image not found at $IMG"
    exit 1
fi

# Очистка экрана
printf "\033[H\033[2J\033[3J"

# --- НАСТРОЙКИ ---
IMG_COLS=45       # Ширина картинки
IMG_ROWS=18       # Высота картинки
GAP=4             # Отступ
TEXT_COL=$((IMG_COLS + GAP))

# --- ОТРИСОВКА КАРТИНКИ ---
kitten icat --clear
kitten icat --place "${IMG_COLS}x${IMG_ROWS}@0x0" --align left "$IMG"

# Цвета
c="\e[1;35m"
r="\e[0m"

# --- ПОЗИЦИОНИРОВАНИЕ ---
printf "\e[1;1H"
printf "\e[${TEXT_COL}G"

print_line() {
    printf "\e[${TEXT_COL}G%b\n" "$1"
}

# --- ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ ДЛЯ БАТАРЕИ ---
get_battery_info() {
    local batt_raw
    local percent
    local status
    local time_left
    local rem_min

    # Получаем сырые данные
    batt_raw=$(pmset -g batt 2>/dev/null | grep -Eo "\d+%; .*" | head -1)

    if [[ -z "$batt_raw" ]]; then
        echo "N/A||Unknown"
        return
    fi

    percent=$(echo "$batt_raw" | cut -d';' -f1 | tr -d ' %')
    status=$(echo "$batt_raw" | cut -d';' -f2 | xargs)

    # Пытаемся получить время в минутах. 
    # Ищем паттерн типа "120 minute" или "120 minutes", берем только цифры.
    rem_min=$(pmset -g batt 2>/dev/null | grep -oE "[0-9]+ minute" | head -1 | grep -oE "[0-9]+" | head -1)

    if [[ -n "$rem_min" ]] && [[ "$rem_min" =~ ^[0-9]+$ ]]; then
        # Безопасная математика
        local h=$((rem_min / 60))
        local m=$((rem_min % 60))
        time_left="${h}h ${m}m"
    else
        # Фоллбэк эвристика, если система не дала точное время
        # Проверяем, что percent это число
        if [[ "$percent" =~ ^[0-9]+$ ]]; then
            local est=$((percent * 3))
            local h=$((est / 60))
            local m=$((est % 60))
            time_left="~${h}h ${m}m"
        else
            time_left="Unknown"
        fi
    fi

    echo "${percent}|${status}|${time_left}"
}

# --- ЛОГИКА РЕЖИМА HELLO ---
if [[ "$MODE" == "hello" ]]; then
    USER_NAME="$USER"
    CURRENT_DATE=$(date "+%B %d, %Y")
    CURRENT_TIME=$(date "+%H:%M")
    DAY_OF_WEEK=$(date "+%A")

    # Получаем данные о батарее через функцию
    IFS='|' read -r BATT_PERCENT BATT_STATUS TIME_LEFT <<< "$(get_battery_info)"

    print_line "${c}Hello, ${USER_NAME}${r}"
    print_line "-------------------"
    print_line "Today is ${c}${DAY_OF_WEEK}${r}, ${c}${CURRENT_DATE}${r}"
    print_line "Current time: ${c}${CURRENT_TIME}${r}"
    print_line "Battery: ${c}${BATT_PERCENT}%${r} ${BATT_STATUS}"
    print_line "Est. time left: ${c}${TIME_LEFT}${r}"
    print_line ""
    print_line "${c}I am at your service.${r}"

# --- ЛОГИКА РЕЖИМА NORMAL ---
else
    print_line "${c}${USER}${r}@${c}$(hostname -s)${r}"
    print_line "-------------------"
    print_line "${c}OS:${r}         macOS $(sw_vers -productVersion)"
    print_line "${c}Host:${r}       $(sysctl -n hw.model)"
    print_line "${c}Kernel:${r}     $(uname -r)"
    print_line "${c}Shell:${r}      zsh $ZSH_VERSION"
    
    CPU=$(sysctl -n machdep.cpu.brand_string | sed 's/(R)//g; s/(TM)//g')
    print_line "${c}CPU:${r}        ${CPU}"
    
    GPU=$(system_profiler SPDisplaysDataType 2>/dev/null | grep -m1 "Chipset Model" | sed 's/.*: //')
    print_line "${c}GPU:${r}        ${GPU:-Unknown}"
    
    MEM_TOTAL=$(($(sysctl -n hw.memsize) / 1024 / 1024 / 1024))
    print_line "${c}Memory:${r}     ${MEM_TOTAL} GB"

    # Батарейка
    IFS='|' read -r BATT_PERCENT _ _ <<< "$(get_battery_info)"
    if [[ "$BATT_PERCENT" != "N/A" ]]; then
        print_line "${c}Battery:${r}    ${BATT_PERCENT}%"
    fi

    print_line ""
    # Цветные квадратики
    printf "\e[${TEXT_COL}G"
    for i in {0..7}; do printf "\e[4${i}m  "; done; printf "${r}\n"
fi

printf "${r}\e[0m"